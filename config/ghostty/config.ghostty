language = ja

# ── Font ──────────────────────────────────────────────────
font-family = "Zed Mono"
font-size = 13
font-thicken = true

# ── Theme ─────────────────────────────────────────────────
theme = dark-transparent

# ── Background ────────────────────────────────────────────
background-opacity = 0.8
background-blur-radius = 0

# ── Window ────────────────────────────────────────────────
window-padding-x = 8
window-padding-y = 8
macos-titlebar-style = transparent
window-theme = dark
